# CryptoGuard - Environment Configuration
# Copy to .env and fill in your values

# DigitalOcean / Gradient AI
GRADIENT_MODEL_ACCESS_KEY=your-key
DIGITALOCEAN_API_TOKEN=your-token

# Agent Endpoints (set after deploying each agent with `gradient agent deploy`)
TOKEN_ANALYZER_ENDPOINT=https://your-token-analyzer.agents.do-ai.run
CONTRACT_AUDITOR_ENDPOINT=https://your-contract-auditor.agents.do-ai.run
MARKET_INTEL_ENDPOINT=https://your-market-intel.agents.do-ai.run

# Agent API Keys (from Gradient AI Control Panel)
TOKEN_ANALYZER_KEY=your-key
CONTRACT_AUDITOR_KEY=your-key
MARKET_INTEL_KEY=your-key

# Optional: External API keys for richer data
# BIRDEYE_API_KEY=your-birdeye-key
# SOLSCAN_API_KEY=your-solscan-pro-key
# ETHERSCAN_API_KEY=your-etherscan-key

# Debug mode (set to 1 for detailed error messages)
# DEBUG=0
